# ============================================================
#  PMP DevSecOps — Variables de entorno de ejemplo
#  NUNCA versionar el archivo .env real
# ============================================================

# Django
SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.production

# Base de datos PostgreSQL
SQL_ENGINE=django.db.backends.postgresql
SQL_DATABASE=pmp_db
SQL_USER=pmp_user
SQL_PASSWORD=cambia-esto-por-password-seguro
SQL_HOST=db
SQL_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO / S3-compatible storage
USE_MINIO=1
MINIO_ROOT_USER=cambia-esto
MINIO_ROOT_PASSWORD=cambia-esto-por-password-largo
MINIO_BUCKET_NAME=pmp-media
MINIO_ENDPOINT=http://minio:9000
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=cambia-esto
AWS_SECRET_ACCESS_KEY=cambia-esto
AWS_STORAGE_BUCKET_NAME=pmp-media

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=cambia-esto
EMAIL_USE_TLS=1

# Seguridad Django (produccion)
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
CSRF_TRUSTED_ORIGINS=https://tu-dominio.com

# Control de acceso por módulo
ENFORCE_MODULE_GROUPS=1
ADMIN_ROUTE_GROUP_RULES={}
MODULE_GROUP_RULES={}

# Celery worker
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
